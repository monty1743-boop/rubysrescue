---
import { withBase } from '../utils/base';

interface Props {
  title: string;
  subtitle?: string;
  eyebrow?: string;
  image?: string;
}

const { title, subtitle, eyebrow, image } = Astro.props;
const hasImage = Boolean(image);
const headerImage = image ? withBase(image) : undefined;
---

<section
  class:list={[
    'relative overflow-hidden',
    hasImage ? 'bg-ruby-900' : 'border-b border-cream-200 bg-gradient-to-br from-ruby-50 via-cream-50 to-sage-50',
  ]}
>
  {
    image && (
      <>
        <img src={headerImage} alt="" class="absolute inset-0 h-full w-full object-cover opacity-30" />
        <div class="absolute inset-0 bg-gradient-to-r from-ruby-900/90 via-ruby-900/75 to-ruby-900/50" />
      </>
    )
  }

  <div class="relative mx-auto max-w-6xl px-4 py-12 md:py-16">
    {eyebrow && (
      <p class:list={['section-label', hasImage ? 'text-ruby-200' : 'text-sage-600']}>{eyebrow}</p>
    )}
    <h1
      class:list={[
        'font-display mt-2 text-4xl font-bold tracking-tight md:text-5xl',
        hasImage ? 'text-white' : 'text-ruby-900',
      ]}
    >
      {title}
    </h1>
    {
      subtitle && (
        <p
          class:list={[
            'mt-4 max-w-2xl text-lg md:text-xl',
            hasImage ? 'text-ruby-100' : 'text-stone-600',
          ]}
        >
          {subtitle}
        </p>
      )
    }
  </div>
</section>
