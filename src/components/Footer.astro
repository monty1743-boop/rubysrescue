---
import { site } from '../data/site';
const year = new Date().getFullYear();
---

<footer class="mt-auto bg-gradient-to-br from-ruby-900 via-ruby-800 to-ruby-900 text-ruby-100">
  <div class="mx-auto max-w-6xl px-4 py-14">
    <div class="grid gap-10 md:grid-cols-2 lg:grid-cols-4">
      <div class="lg:col-span-2">
        <div class="flex items-center gap-3">
          <img src="/images/logosmaller.png" alt="" class="h-14 rounded-xl bg-white/10 p-1" />
          <div>
            <h2 class="font-display text-xl font-bold text-white">{site.name}</h2>
            <p class="text-sm text-ruby-200">McLean, Illinois</p>
          </div>
        </div>
        <p class="mt-4 max-w-md text-sm leading-relaxed text-ruby-200">{site.tagline}</p>
        <div class="mt-5 flex gap-3">
          <a href={site.facebook} target="_blank" rel="noopener noreferrer" class="rounded-full bg-white/10 p-2.5 transition hover:bg-white/20" aria-label="Facebook">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
          <a href={`mailto:${site.email}`} class="rounded-full bg-white/10 p-2.5 transition hover:bg-white/20" aria-label="Email">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
          </a>
          <a href={site.phoneTel} class="rounded-full bg-white/10 p-2.5 transition hover:bg-white/20" aria-label="Phone">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          </a>
        </div>
      </div>

      <div>
        <h3 class="font-display font-semibold text-white">Visit Us</h3>
        <ul class="mt-3 space-y-2 text-sm text-ruby-200">
          <li>{site.address}</li>
          <li><a href={site.phoneTel} class="hover:text-white">{site.phone}</a></li>
          <li><a href={`mailto:${site.email}`} class="hover:text-white">{site.email}</a></li>
        </ul>
        <p class="mt-3 text-xs text-ruby-300">Please call ahead to schedule your visit.</p>
      </div>

      <div>
        <h3 class="font-display font-semibold text-white">Quick Links</h3>
        <ul class="mt-3 space-y-2 text-sm">
          <li><a href="/available" class="text-ruby-200 hover:text-white">Dogs Available</a></li>
          <li><a href="/application" class="text-ruby-200 hover:text-white">Adoption Application</a></li>
          <li><a href="/help-us" class="text-ruby-200 hover:text-white">Donate &amp; Help</a></li>
          <li><a href={site.petMicrochipLookup} target="_blank" rel="noopener noreferrer" class="text-ruby-200 hover:text-white">Microchip Lookup</a></li>
          <li><a href={site.dogFoodAdvisor} target="_blank" rel="noopener noreferrer" class="text-ruby-200 hover:text-white">Dog Food Advisor</a></li>
        </ul>
      </div>
    </div>
  </div>

  <div class="border-t border-ruby-700/50 px-4 py-5 text-center text-xs text-ruby-300">
    <p>&copy; {year} {site.name}. All rights reserved.</p>
  </div>
</footer>
