---
import PayPalDonate from './PayPalDonate.astro';
import { site } from '../data/site';
---

<aside class="space-y-6">
  <div class="overflow-hidden rounded-2xl border border-ruby-200 bg-white shadow-sm">
    <img src="/images/img0004.png" alt="Rescue dog" class="h-40 w-full object-cover" />
    <div class="p-5">
      <p class="text-sm leading-relaxed text-stone-600">
        {site.tagline}
      </p>
    </div>
  </div>

  <div class="rounded-2xl border border-ruby-200 bg-white p-5 shadow-sm">
    <h3 class="font-semibold text-ruby-800">Send us the things we need</h3>
    <p class="mt-2 text-sm text-stone-600">Shop our wishlists — a portion of each purchase supports the rescue.</p>
    <div class="mt-4 flex flex-wrap gap-3">
      <a
        href={site.amazonWishlist}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 rounded-lg bg-warm-100 px-4 py-2 text-sm font-medium text-warm-800 transition hover:bg-warm-100/80"
      >
        <img src="/images/2kcj7eisui.jpg" alt="" class="h-8 w-12 rounded object-cover" />
        Amazon Wishlist
      </a>
    </div>
  </div>

  <div class="rounded-2xl border border-ruby-200 bg-white p-5 shadow-sm">
    <h3 class="font-semibold text-ruby-800">Donate with PayPal</h3>
    <p class="mt-2 text-sm text-stone-600">Every donation helps us save more dogs.</p>
    <div class="mt-4">
      <PayPalDonate />
    </div>
  </div>

  <a
    href={site.applicationUrl}
    target="_blank"
    rel="noopener noreferrer"
    class="block overflow-hidden rounded-2xl border border-ruby-200 bg-white shadow-sm transition hover:shadow-md"
  >
    <img src="/images/img0001.png" alt="Submit adoption application" class="w-full" />
    <p class="p-4 text-center text-sm font-semibold text-ruby-700 underline">Submit Application</p>
  </a>
</aside>
