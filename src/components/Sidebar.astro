---
import PayPalDonate from './PayPalDonate.astro';
import { site } from '../data/site';
---

<aside class="space-y-5 lg:sticky lg:top-36">
  <div class="card overflow-hidden">
    <img src="/images/rottie.jpg" alt="Rescue dog at Ruby's" class="h-44 w-full object-cover" />
    <div class="bg-gradient-to-br from-ruby-50 to-cream-50 p-5">
      <p class="font-display text-lg font-semibold text-ruby-800">Our Mission</p>
      <p class="mt-2 text-sm leading-relaxed text-stone-600">{site.tagline}</p>
    </div>
  </div>

  <div class="card p-5">
    <div class="flex items-center gap-3">
      <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-sage-100 text-lg">🎁</div>
      <h3 class="font-display font-semibold text-ruby-800">Wishlists</h3>
    </div>
    <p class="mt-3 text-sm text-stone-600">Send supplies directly — every item helps a dog in our care.</p>
    <div class="mt-4 space-y-2">
      <a href={site.amazonWishlist} target="_blank" rel="noopener noreferrer" class="card-hover flex items-center gap-3 rounded-2xl border border-cream-200 p-3">
        <img src="/images/2kcj7eisui.jpg" alt="" class="h-10 w-14 rounded-lg object-cover" />
        <span class="text-sm font-semibold text-ruby-800">Amazon Wishlist</span>
      </a>
      <a href={site.chewyWishlist} target="_blank" rel="noopener noreferrer" class="card-hover flex items-center gap-3 rounded-2xl border border-cream-200 p-3">
        <div class="flex h-10 w-14 items-center justify-center rounded-lg bg-blue-100 text-sm font-bold text-blue-700">C</div>
        <span class="text-sm font-semibold text-ruby-800">Chewy Wish List</span>
      </a>
    </div>
  </div>

  <div class="card bg-gradient-to-br from-sage-50 to-white p-5">
    <div class="flex items-center gap-3">
      <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-sage-100 text-lg">💚</div>
      <h3 class="font-display font-semibold text-ruby-800">Donate</h3>
    </div>
    <p class="mt-3 text-sm text-stone-600">Your gift saves lives — vet care, food, and shelter for dogs in need.</p>
    <div class="mt-4">
      <PayPalDonate />
    </div>
  </div>

</aside>
