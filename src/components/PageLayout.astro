---
interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<div class:list={['mx-auto max-w-6xl px-4 py-10 md:py-12', className]}>
  <div class="grid gap-10 lg:grid-cols-[1fr_320px] lg:items-start">
    <div class="min-w-0">
      <slot name="main" />
    </div>
    <aside class="min-w-0">
      <slot name="sidebar" />
    </aside>
  </div>
</div>
