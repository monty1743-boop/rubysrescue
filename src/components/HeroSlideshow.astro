---
import { heroImages } from '../data/site';
---

<section class="relative overflow-hidden rounded-2xl shadow-lg" aria-label="Photo gallery">
  <div class="slideshow relative aspect-[16/9] w-full bg-stone-900">
    {
      heroImages.map((src, index) => (
        <img
          src={src}
          alt=""
          class:list={['slideshow-slide absolute inset-0 h-full w-full object-cover', index === 0 && 'is-active']}
          loading={index === 0 ? 'eager' : 'lazy'}
        />
      ))
    }
    <div class="absolute inset-0 bg-gradient-to-t from-black/50 via-transparent to-transparent"></div>
  </div>

  <div class="absolute bottom-4 left-4 right-4 flex justify-center gap-2">
    {
      heroImages.map((_, index) => (
        <button
          type="button"
          class="slideshow-dot h-2.5 w-2.5 rounded-full bg-white/50 transition hover:bg-white"
          data-index={index}
          aria-label={`Show slide ${index + 1}`}
        />
      ))
    }
  </div>
</section>

<script>
  const slides = document.querySelectorAll<HTMLImageElement>('.slideshow-slide');
  const dots = document.querySelectorAll<HTMLButtonElement>('.slideshow-dot');
  let current = 0;

  function showSlide(index: number) {
    slides[current]?.classList.remove('is-active');
    dots[current]?.classList.remove('bg-white');
    dots[current]?.classList.add('bg-white/50');
    current = index;
    slides[current]?.classList.add('is-active');
    dots[current]?.classList.remove('bg-white/50');
    dots[current]?.classList.add('bg-white');
  }

  dots.forEach((dot) => {
    dot.addEventListener('click', () => {
      const index = Number(dot.dataset.index);
      showSlide(index);
    });
  });

  if (slides.length > 1) {
    setInterval(() => showSlide((current + 1) % slides.length), 5000);
  }

  dots[0]?.classList.add('bg-white');
</script>

<style>
  .slideshow-slide {
    opacity: 0;
    transition: opacity 0.8s ease-in-out;
  }

  .slideshow-slide.is-active {
    opacity: 1;
  }
</style>
