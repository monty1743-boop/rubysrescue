---
import { site } from '../data/site';
---

<div class="petfinder-widget min-h-[400px] rounded-2xl border border-ruby-200 bg-white p-4 shadow-sm">
  <pet-scroller
    s3Url="https://dbw3zep4prcju.cloudfront.net/"
    apiBase="https://psl.petfinder.com/graphql"
    organization={`["${site.petfinderOrgId}"]`}
    status="adoptable"
    petfinderUrl="https://www.petfinder.com/"
    hideBreed="false"
    limit="24"
    petListTitle="Our Adoptable Dogs"
  ></pet-scroller>
</div>

<script src="https://www.petfinder.com/pet-scroller.bundle.js" is:inline></script>
