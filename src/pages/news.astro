---
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
import PageLayout from '../components/PageLayout.astro';
import Sidebar from '../components/Sidebar.astro';
import { newsItems } from '../data/site';
---

<Layout
  title="News"
  description="News and stories from Ruby's Rescue and Retreat."
>
  <PageHeader
    eyebrow="Community"
    title="News at Ruby's"
    subtitle="Stories, awards, and updates from our rescue community."
  />

  <PageLayout>
    <div slot="main" class="space-y-6">
      {
        newsItems.map((item) => (
          <article class="card overflow-hidden">
            {'image' in item && item.image && (
              <img src={item.image} alt={item.title} class="max-h-80 w-full object-cover" />
            )}
            <div class="p-6 md:p-8">
              <h2 class="font-display text-2xl font-bold text-ruby-800">{item.title}</h2>
              <p class="mt-3 text-stone-600">{item.description}</p>

              {'href' in item && item.href && (
                <a href={item.href} target="_blank" rel="noopener noreferrer" class="btn btn-secondary mt-5">
                  Read full article
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
                </a>
              )}

              {'video' in item && item.video && (
                <video controls preload="metadata" class="mt-6 w-full rounded-2xl shadow-inner" title={item.title}>
                  <source src={item.video} type="video/mp4" />
                  Your browser does not support the video tag.
                </video>
              )}
            </div>
          </article>
        ))
      }
    </div>
    <Sidebar slot="sidebar" />
  </PageLayout>
</Layout>
