---
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
import PageLayout from '../components/PageLayout.astro';
import Sidebar from '../components/Sidebar.astro';
import { withBase } from '../utils/base';
import { site } from '../data/site';
---

<Layout
  title="Boarding"
  description="Ruby's Rescue and Retreat offers dog boarding services in McLean, Illinois."
>
  <PageHeader
    eyebrow="Services"
    title="Dog Boarding"
    subtitle="Trusted care in a loving environment — call for availability and pricing."
    image="/images/Web5.jpg"
  />

  <PageLayout>
    <div slot="main" class="card overflow-hidden">
      <div class="grid md:grid-cols-2">
        <div class="p-6 md:p-8">
          <p class="font-display text-2xl font-bold text-ruby-700">Ruby's now offers boarding!</p>
          <div class="prose-content mt-4 space-y-4">
            <p>
              In addition to our rescue work, we provide basic dog boarding services. All dogs here
              enjoy plenty of exercise, socialization, and love — whether boarding or waiting for a
              new home.
            </p>
            <p>
              Call for availability and pricing:
              <a href={site.phoneTel} class="font-semibold text-ruby-700 underline">{site.phone}</a>
            </p>
          </div>
          <a href={site.phoneTel} class="btn btn-primary mt-6">Call to Book</a>
        </div>
        <img src={withBase('/images/img0005.png')} alt="Boarding at Ruby's Rescue and Retreat" class="h-full min-h-[280px] w-full object-cover" />
      </div>
    </div>
    <Sidebar slot="sidebar" />
  </PageLayout>
</Layout>
