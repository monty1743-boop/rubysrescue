---
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
import PageLayout from '../components/PageLayout.astro';
import Sidebar from '../components/Sidebar.astro';
import { site } from '../data/site';
---

<Layout
  title="Application"
  description="Fill out an adoption application for Ruby's Rescue and Retreat."
>
  <PageHeader
    eyebrow="Adoption"
    title="Adoption Application"
    subtitle="Please allow 10–15 minutes to complete the full application."
    image="/images/jeankane.jpg"
  />

  <PageLayout>
    <div slot="main" class="card p-6 md:p-8">
      <div class="prose-content space-y-4">
        <p>
          Please make sure to fully answer each question. Our adoption application is hosted
          through Shelter Manager — when you are ready, click below to open it in a new tab.
        </p>
      </div>

      <div class="mt-8 flex flex-col items-start gap-4 sm:flex-row sm:items-center">
        <a href={site.applicationUrl} target="_blank" rel="noopener noreferrer" class="btn btn-primary !px-7 !py-3.5 !text-base">
          Go to Application
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
        </a>
        <p class="text-sm text-stone-500">Opens in a new window · Powered by Shelter Manager</p>
      </div>

      <div class="mt-10 rounded-2xl border border-sage-200 bg-sage-50 p-5 text-sm text-stone-600">
        <p>
          <strong class="text-ruby-800">Questions?</strong> Call us at
          <a href={site.phoneTel} class="font-semibold text-ruby-700 underline">{site.phone}</a>
          or email
          <a href={`mailto:${site.email}`} class="font-semibold text-ruby-700 underline">{site.email}</a>.
        </p>
      </div>
    </div>
    <Sidebar slot="sidebar" />
  </PageLayout>
</Layout>
