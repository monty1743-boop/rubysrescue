---
import Layout from '../layouts/Layout.astro';
import Sidebar from '../components/Sidebar.astro';
import { site } from '../data/site';
---

<Layout
  title="Application"
  description="Fill out an adoption application for Ruby's Rescue and Retreat."
>
  <div class="grid gap-8 lg:grid-cols-[1fr_280px]">
    <section class="rounded-2xl border border-ruby-200 bg-white p-6 shadow-sm md:p-8">
      <h1 class="text-3xl font-bold text-ruby-800">Adoption Application</h1>

      <div class="mt-6 space-y-4 text-stone-700">
        <p class="text-lg">
          Please allow 10–15 minutes to complete the full application. Please make sure to fully
          answer each question.
        </p>
        <p>
          Our adoption application is hosted through Shelter Manager, our shelter management
          system. When you are ready, click the button below to open the application in a new tab.
        </p>
      </div>

      <div class="mt-8 flex flex-col items-start gap-4 sm:flex-row sm:items-center">
        <a
          href={site.applicationUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-lg bg-ruby-600 px-6 py-3 text-base font-semibold text-white transition hover:bg-ruby-700"
        >
          Go to Application
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
        </a>
        <p class="text-sm text-stone-500">Opens in a new window · Powered by Shelter Manager</p>
      </div>

      <div class="mt-10 rounded-xl bg-ruby-50 p-5 text-sm text-stone-600">
        <p>
          <strong class="text-ruby-800">Questions?</strong> Call us at
          <a href={site.phoneTel} class="text-ruby-700 underline">{site.phone}</a>
          or email
          <a href={`mailto:${site.email}`} class="text-ruby-700 underline">{site.email}</a>.
        </p>
      </div>
    </section>

    <Sidebar />
  </div>
</Layout>
