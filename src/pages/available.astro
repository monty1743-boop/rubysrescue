---
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
import PageLayout from '../components/PageLayout.astro';
import Sidebar from '../components/Sidebar.astro';
import PetfinderEmbed from '../components/PetfinderEmbed.astro';
---

<Layout
  title="Dogs Available"
  description="Browse adoptable dogs at Ruby's Rescue and Retreat in McLean, Illinois."
>
  <PageHeader
    eyebrow="Find Your New Best Friend"
    title="Dogs Available for Adoption"
    subtitle="Each dog has been vetted and is ready for a loving home. Complete our application to get started."
    image="/images/Web3.jpg"
  />

  <PageLayout>
    <div slot="main">
      <PetfinderEmbed />
    </div>
    <Sidebar slot="sidebar" />
  </PageLayout>
</Layout>
