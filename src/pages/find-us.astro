---
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
import PageLayout from '../components/PageLayout.astro';
import Sidebar from '../components/Sidebar.astro';
import { site } from '../data/site';
---

<Layout
  title="Find Us"
  description="Visit Ruby's Rescue and Retreat in McLean, Illinois. Call or email to schedule your visit."
>
  <PageHeader
    eyebrow="Location"
    title="Find Us"
    subtitle="Call or email us to schedule your visit!"
  />

  <PageLayout>
    <div slot="main" class="space-y-6">
      <div class="card p-6 md:p-8">
        <div class="grid gap-6 sm:grid-cols-3">
          <div>
            <p class="section-label">Address</p>
            <p class="mt-2 font-medium text-ruby-800">{site.address}</p>
          </div>
          <div>
            <p class="section-label">Phone</p>
            <a href={site.phoneTel} class="mt-2 block font-medium text-ruby-700 hover:underline">{site.phone}</a>
          </div>
          <div>
            <p class="section-label">Email</p>
            <a href={`mailto:${site.email}`} class="mt-2 block font-medium text-ruby-700 hover:underline">{site.email}</a>
          </div>
        </div>
        <p class="mt-6 rounded-2xl bg-cream-100 px-4 py-3 text-sm text-stone-600">
          We are a small private facility — please make an appointment before visiting.
        </p>
      </div>

      <div class="card overflow-hidden">
        <iframe
          src={site.googleMapsEmbed}
          width="100%"
          height="420"
          style="border:0"
          allowfullscreen
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Map to Ruby's Rescue and Retreat"
        ></iframe>
      </div>
    </div>
    <Sidebar slot="sidebar" />
  </PageLayout>
</Layout>
