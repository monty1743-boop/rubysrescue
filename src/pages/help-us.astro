---
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
import PageLayout from '../components/PageLayout.astro';
import Sidebar from '../components/Sidebar.astro';
import { site } from '../data/site';
---

<Layout
  title="Help Us"
  description="Support Ruby's Rescue and Retreat through wishlists, donations, and shopping links."
>
  <PageHeader
    eyebrow="Support Our Mission"
    title="Help Us Out"
    subtitle="A portion of each purchase gets donated to us — every bit helps save a life."
    image="/images/barn.jpg"
  />

  <PageLayout>
    <div slot="main" class="space-y-6">
      <div class="grid gap-5 sm:grid-cols-2">
        <a href={site.chewyWishlist} target="_blank" rel="noopener noreferrer" class="card card-hover group p-6">
          <div class="flex h-14 w-14 items-center justify-center rounded-2xl bg-blue-100 text-2xl font-bold text-blue-700">C</div>
          <h2 class="font-display mt-5 text-xl font-bold text-ruby-800 group-hover:text-ruby-600">Chewy Wish List</h2>
          <p class="mt-2 text-sm leading-relaxed text-stone-600">Shop food and supplies directly for the rescue through our Chewy wish list.</p>
          <span class="mt-4 inline-block text-sm font-semibold text-ruby-600">Shop Chewy →</span>
        </a>

        <a href={site.amazonWishlist} target="_blank" rel="noopener noreferrer" class="card card-hover group p-6">
          <img src="/images/2kcj7eisui.jpg" alt="" class="h-14 w-24 rounded-xl object-cover" />
          <h2 class="font-display mt-5 text-xl font-bold text-ruby-800 group-hover:text-ruby-600">Amazon Wishlist</h2>
          <p class="mt-2 text-sm leading-relaxed text-stone-600">Send us the things we need through our Amazon wish list.</p>
          <span class="mt-4 inline-block text-sm font-semibold text-ruby-600">Shop Amazon →</span>
        </a>
      </div>

      <div class="card bg-gradient-to-br from-ruby-50 to-cream-50 p-6 md:p-8">
        <h2 class="font-display text-xl font-bold text-ruby-800">Other Ways to Help</h2>
        <ul class="mt-4 grid gap-3 sm:grid-cols-2">
          <li class="flex items-start gap-2 text-sm text-stone-600"><span class="text-ruby-500">✓</span> Make a PayPal donation</li>
          <li class="flex items-start gap-2 text-sm text-stone-600"><span class="text-ruby-500">✓</span> Volunteer — call ahead to schedule</li>
          <li class="flex items-start gap-2 text-sm text-stone-600"><span class="text-ruby-500">✓</span> Share our Facebook group</li>
          <li class="flex items-start gap-2 text-sm text-stone-600"><span class="text-ruby-500">✓</span> Adopt — browse dogs &amp; apply</li>
        </ul>
      </div>
    </div>
    <Sidebar slot="sidebar" />
  </PageLayout>
</Layout>
