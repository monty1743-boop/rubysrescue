---
import Layout from '../layouts/Layout.astro';
import Sidebar from '../components/Sidebar.astro';
import { site } from '../data/site';
---

<Layout
  title="Help Us"
  description="Support Ruby's Rescue and Retreat through wishlists, donations, and shopping links."
>
  <div class="grid gap-8 lg:grid-cols-[1fr_280px]">
    <section class="rounded-2xl border border-ruby-200 bg-white p-6 shadow-sm md:p-8">
      <h1 class="text-3xl font-bold text-ruby-800">Help Us Out</h1>
      <p class="mt-4 text-lg text-stone-700">
        Help us out by shopping at the following links. A portion of each sale gets donated to us!
      </p>

      <div class="mt-8 grid gap-6 sm:grid-cols-2">
        <a
          href={site.chewyWishlist}
          target="_blank"
          rel="noopener noreferrer"
          class="group rounded-xl border border-ruby-200 p-6 transition hover:border-ruby-400 hover:shadow-md"
        >
          <div class="flex h-12 w-12 items-center justify-center rounded-lg bg-blue-100 text-xl font-bold text-blue-700">
            C
          </div>
          <h2 class="mt-4 text-lg font-semibold text-ruby-800 group-hover:text-ruby-600">
            Chewy Wish List
          </h2>
          <p class="mt-2 text-sm text-stone-600">
            Shop supplies directly for the rescue through our Chewy wish list.
          </p>
        </a>

        <a
          href={site.amazonWishlist}
          target="_blank"
          rel="noopener noreferrer"
          class="group rounded-xl border border-ruby-200 p-6 transition hover:border-ruby-400 hover:shadow-md"
        >
          <img src="/images/2kcj7eisui.jpg" alt="" class="h-12 w-20 rounded object-cover" />
          <h2 class="mt-4 text-lg font-semibold text-ruby-800 group-hover:text-ruby-600">
            Amazon Wishlist
          </h2>
          <p class="mt-2 text-sm text-stone-600">
            Send us the things we need through our Amazon wish list.
          </p>
        </a>
      </div>

      <div class="mt-10 rounded-xl bg-ruby-50 p-6">
        <h2 class="text-lg font-semibold text-ruby-800">Other Ways to Help</h2>
        <ul class="mt-3 list-inside list-disc space-y-2 text-stone-700">
          <li>Make a PayPal donation (see sidebar)</li>
          <li>Volunteer — call ahead to schedule a visit</li>
          <li>Share our Facebook group with friends and family</li>
          <li>Adopt — browse our available dogs and submit an application</li>
        </ul>
      </div>
    </section>

    <Sidebar />
  </div>
</Layout>
