---
import Layout from '../layouts/Layout.astro';
import HeroSlideshow from '../components/HeroSlideshow.astro';
import Sidebar from '../components/Sidebar.astro';
import { site } from '../data/site';
---

<Layout
  title="Home"
  description="Ruby's Rescue and Retreat is an animal shelter and boarding facility in Central Illinois, saving dogs from high-kill shelters and finding them loving homes."
>
  <div class="grid gap-8 lg:grid-cols-[1fr_280px]">
    <div class="space-y-8">
      <HeroSlideshow />

      <section class="rounded-2xl border border-ruby-200 bg-white p-6 shadow-sm md:p-8">
        <h1 class="text-3xl font-bold text-ruby-800">Welcome to {site.name}</h1>
        <p class="mt-1 text-stone-500">Founded and owned by {site.owner}</p>

        <div class="mt-6 space-y-4 text-lg leading-relaxed text-stone-700">
          <p>
            We take in dogs from high-kill shelters, make them healthy again, and then find them
            wonderful homes.
          </p>
          <p>
            We are located just south of Bloomington, and not far from Lincoln or Springfield. All
            the dogs here enjoy plenty of exercise, socialization, and love while waiting for a new
            home.
          </p>
          <p>
            We love volunteers! However, we are a small private facility, and we do request that
            you make an appointment prior to visiting.
          </p>
        </div>

        <div class="mt-8 flex flex-wrap gap-3">
          <a
            href={site.phoneTel}
            class="rounded-lg bg-ruby-600 px-5 py-3 text-sm font-semibold text-white transition hover:bg-ruby-700"
          >
            Call {site.phone}
          </a>
          <a
            href={`mailto:${site.email}`}
            class="rounded-lg border border-ruby-300 px-5 py-3 text-sm font-semibold text-ruby-700 transition hover:bg-ruby-50"
          >
            Email Us
          </a>
          <a
            href={site.applicationUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="rounded-lg border border-ruby-300 px-5 py-3 text-sm font-semibold text-ruby-700 transition hover:bg-ruby-50"
          >
            Adoption Application
          </a>
        </div>
      </section>
    </div>

    <Sidebar />
  </div>
</Layout>
